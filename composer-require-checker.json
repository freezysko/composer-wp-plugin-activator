{
  "symbol-whitelist": [
    "Composer\\Composer",
    "Composer\\EventDispatcher\\EventSubscriberInterface",
    "Composer\\IO\\IOInterface",
    "Composer\\Plugin\\PluginInterface",
    "Composer\\Script\\Event",
    "Composer\\Script\\ScriptEvents",
    "Composer\\Util\\ProcessExecutor",
    "posix_getuid"
